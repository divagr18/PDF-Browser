# --- Django ---
# Default SQLite database
db.sqlite3
db.sqlite3-journal

# User-uploaded files (MEDIA_ROOT)
media/

# Static files (collected by collectstatic)
# Note: Some deployment strategies might require committing this.
# Usually, it's better to run collectstatic during deployment.
staticfiles/
assets/

# Session files (if using file-based sessions)
django_sessions/

# Log files
*.log
logs/
__pycache__
# --- Project Specific ---
# Vector Store directory
vector_stores/

# Celery beat schedule file (if using Celery Beat)
celerybeat-schedule
celerybeat.pid

